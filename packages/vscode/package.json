{
  "name": "flightdeck-vscode",
  "displayName": "Flightdeck",
  "description": "Multi-agent orchestration for AI coding agents",
  "version": "0.1.0",
  "publisher": "flightdeck-ai",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onView:flightdeck.tasks",
    "onView:flightdeck.agents",
    "workspaceContains:.flightdeck.json"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "flightdeck",
          "title": "Flightdeck",
          "icon": "$(rocket)"
        }
      ]
    },
    "views": {
      "flightdeck": [
        { "id": "flightdeck.tasks", "name": "Tasks" },
        { "id": "flightdeck.agents", "name": "Agents" }
      ]
    },
    "commands": [
      { "command": "flightdeck.setProject", "title": "Flightdeck: Set Project", "icon": "$(project)" },
      { "command": "flightdeck.createTask", "title": "Flightdeck: Create Task", "icon": "$(add)" },
      { "command": "flightdeck.chatWithLead", "title": "Flightdeck: Chat with Lead", "icon": "$(comment-discussion)" },
      { "command": "flightdeck.viewDashboard", "title": "Flightdeck: Open Dashboard", "icon": "$(globe)" },
      { "command": "flightdeck.refreshAll", "title": "Flightdeck: Refresh All", "icon": "$(refresh)" },
      { "command": "flightdeck.startGateway", "title": "Flightdeck: Start Gateway", "icon": "$(play)" },
      { "command": "flightdeck.status", "title": "Flightdeck: Show Status" },
      { "command": "flightdeck.taskDetail", "title": "Flightdeck: Task Detail" },
      { "command": "flightdeck.statusBarClick", "title": "Flightdeck: Quick Menu" },
      { "command": "flightdeck.agentTerminate", "title": "Terminate Agent", "icon": "$(trash)" },
      { "command": "flightdeck.agentRestart", "title": "Restart Agent", "icon": "$(debug-restart)" },
      { "command": "flightdeck.agentSendMessage", "title": "Send Message to Agent", "icon": "$(mail)" }
    ],
    "keybindings": [
      { "command": "flightdeck.chatWithLead", "key": "ctrl+shift+f", "mac": "cmd+shift+f" },
      { "command": "flightdeck.refreshAll", "key": "ctrl+shift+r", "mac": "cmd+shift+r", "when": "view =~ /flightdeck/" }
    ],
    "configuration": {
      "title": "Flightdeck",
      "properties": {
        "flightdeck.gatewayUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "URL of the Flightdeck gateway server"
        },
        "flightdeck.defaultProject": {
          "type": "string",
          "default": "",
          "description": "Default project name (auto-detected from .flightdeck.json if empty)"
        },
        "flightdeck.authToken": {
          "type": "string",
          "default": "",
          "description": "Authentication token for the gateway API"
        }
      }
    },
    "menus": {
      "view/title": [
        { "command": "flightdeck.refreshAll", "when": "view =~ /flightdeck/", "group": "navigation" },
        { "command": "flightdeck.createTask", "when": "view == flightdeck.tasks", "group": "navigation" },
        { "command": "flightdeck.chatWithLead", "when": "view =~ /flightdeck/", "group": "navigation" }
      ],
      "view/item/context": [
        { "command": "flightdeck.agentTerminate", "when": "viewItem == agent", "group": "agent@1" },
        { "command": "flightdeck.agentRestart", "when": "viewItem == agent", "group": "agent@2" },
        { "command": "flightdeck.agentSendMessage", "when": "viewItem == agent", "group": "agent@3" }
      ]
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  }
}
