{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Flightdeck Global Configuration",
  "description": "Global configuration for Flightdeck gateway (~/.flightdeck/v2/config.yaml)",
  "type": "object",
  "properties": {
    "customRuntimes": {
      "type": "object",
      "description": "User-defined ACP runtimes",
      "additionalProperties": {
        "type": "object",
        "required": ["name", "command"],
        "properties": {
          "name": { "type": "string", "description": "Display name" },
          "command": { "type": "string", "description": "ACP binary command (must support --stdio)" },
          "args": { "type": "array", "items": { "type": "string" }, "description": "Additional CLI arguments" },
          "env": { "type": "object", "additionalProperties": { "type": "string" }, "description": "Environment variables" },
          "icon": { "type": "string", "description": "Emoji icon for UI" },
          "supportsSessionLoad": { "type": "boolean", "description": "Whether this runtime supports session resume", "default": false }
        },
        "additionalProperties": false
      }
    },
    "defaultRuntime": {
      "type": "string",
      "description": "Default runtime for new agents (e.g. 'codex', 'copilot')"
    },
    "auth": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["none", "token"] },
        "token": { "type": "string" }
      },
      "additionalProperties": false
    },
    "bind": {
      "type": "string",
      "description": "Gateway bind address (default: 127.0.0.1)"
    },
    "port": {
      "type": "integer",
      "description": "Gateway port (default: 18800)"
    },
    "runtimeOrder": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Ordered list of runtime IDs for UI display"
    },
    "disabledRuntimes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Runtime IDs to hide from the UI"
    },
    "timezone": {
      "type": "string",
      "description": "IANA timezone (e.g. 'America/Los_Angeles')"
    },
    "display": {
      "type": "object",
      "properties": {
        "thinking": { "type": "boolean", "description": "Show thinking/reasoning blocks" },
        "toolCalls": { "type": "string", "description": "Tool call display mode" },
        "flightdeckTools": { "type": "string", "description": "Flightdeck tool display mode" },
        "agentStreaming": { "type": "boolean", "description": "Enable agent streaming" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
